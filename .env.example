# ============================================================
# LLM プロバイダー選択
# 値: gemini / claude / openai
# ============================================================
LLM_PROVIDER=gemini

# ============================================================
# Gemini (Google) - 無料枠あり
# https://aistudio.google.com/app/apikey
# 無料枠: gemini-1.5-flash で 1,500 リクエスト/日、100万トークン/月
# ============================================================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ============================================================
# Claude (Anthropic) - 従量課金
# https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ============================================================
# OpenAI - 新規アカウントに試用クレジットあり
# https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# arXiv 収集設定
# ARXIV_TOPICS: カンマ区切りで複数トピック指定可能
# ============================================================
ARXIV_TOPICS=RAG,retrieval augmented generation
ARXIV_MAX_RESULTS_PER_TOPIC=20
ARXIV_DAYS_BACK=1

# ============================================================
# スケジュール (JST)
# DAILY_SCHEDULE_TIME: 毎日の実行時刻 (HH:MM)
# WEEKLY_SCHEDULE_DAY: 週次合成の曜日 (mon/tue/wed/thu/fri/sat/sun)
# ============================================================
DAILY_SCHEDULE_TIME=09:00
WEEKLY_SCHEDULE_DAY=mon

# ============================================================
# データ保存パス (変更不要)
# ============================================================
DB_PATH=data/db/papers.db
VECTOR_DB_PATH=data/vector/chroma
OUTPUT_DIR=output/reports
